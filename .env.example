# local or production
JOBLINK_ENV=local

# Required before public deployment. Use a long random value.
JOBLINK_SECRET_KEY=replace-me

# Mode-sensitive defaults keep capture local-only and redact production URLs.
# JOBLINK_CAPTURE_ENABLED=true
JOBLINK_EXPOSE_ISSUES=false
# JOBLINK_STORE_FULL_URLS=true

# Set only behind a trusted reverse proxy.
JOBLINK_TRUST_PROXY_HOPS=0

JOBLINK_MAX_JOBS=20
JOBLINK_MAX_UPLOAD_MB=12
JOBLINK_MAX_WORKBOOK_UNCOMPRESSED_MB=80
JOBLINK_RATE_WINDOW_SECONDS=600

# Background scraping stays deliberately small for the beta.
JOBLINK_SCRAPE_WORKERS=2
JOBLINK_MAX_PENDING_JOBS=25
JOBLINK_JOB_TTL_SECONDS=1800
JOBLINK_SCRAPE_CAPACITY_WAIT_SECONDS=2
JOBLINK_RATE_LIMIT_JOB_CREATE=10

# Maximum navigation time for one browser attempt.
JOBLINK_SCRAPE_PAGE_TIMEOUT_SECONDS=60

# Production containers normally need this because shared memory is small.
# JOBLINK_CHROMIUM_DISABLE_DEV_SHM_USAGE=true

# Production defaults to JSON logs and verifies Chromium during startup.
# JOBLINK_JSON_LOGS=true
JOBLINK_LOG_LEVEL=INFO
JOBLINK_REQUEST_LOGGING=true
# JOBLINK_VERIFY_BROWSER_ON_STARTUP=true

# Gunicorn HTTP threads are separate from browser scraping workers.
JOBLINK_HTTP_THREADS=4
