{
  "manifest_version": 3,
  "name": "JobLink Capture",
  "version": "0.2.2",
  "description": "Send the job page you have open to the JobLink app on your computer.",
  "permissions": ["activeTab", "scripting", "tabs"],
  "host_permissions": [
    "http://127.0.0.1:5050/*",
    "http://localhost:5050/*"
  ],
  "action": {
    "default_title": "JobLink Capture",
    "default_popup": "popup.html"
  }
}
